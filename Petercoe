	local heartbeatConn = nil

	local function setRunning(state)
		estado.running = state

		if estado.running then
			tween(farmBtn, { BackgroundColor3 = COLOR.danger }, 0.25)
			farmBtnText.Text = "■  PARAR AUTO FARM"
			farmBtnText.TextColor3 = Color3.fromRGB(42, 10, 13)

