local function contarTodosCogumelosNoMapa()
	local total = 0
	for _, obj in ipairs(workspace:GetDescendants()) do
		if string.find(string.lower(obj.Name), "mushroom") then
			total += 1
		end
	end
	return total
end

local function encontrarCogumelosAlvo()
	local cogumelos = {}
	for _, obj in ipairs(workspace:GetDescendants()) do
		local nomeLower = string.lower(obj.Name)
		if nomeLower == "mushroom-01" or nomeLower == "mushroom-02" then
			local pos = nil
			if obj:IsA("BasePart") then
				pos = obj.Position
			elseif obj.Parent and obj.Parent:IsA("BasePart") then
				pos = obj.Parent.Position
			else
				for _, desc in ipairs(obj:GetDescendants()) do
					if desc:IsA("BasePart") then
						pos = desc.Position
						break
					end
				end
			end
			if pos then
				table.insert(cogumelos, { nome = obj.Name, posicao = pos, objeto = obj })
			end
		end
	end
	table.sort(cogumelos, function(a, b) return a.nome < b.nome end)
	return cogumelos
end

local function teleportarPara(posicao)
	if not humanoidRootPart then return end
	humanoidRootPart.CFrame = CFrame.new(posicao + Vector3.new(0, CONFIG.offsetY, 0))
end

local function segurarE(duracao)
	VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.E, false, game)
	local inicio = tick()
	while tick() - inicio < duracao do
		task.wait(0.1)
	end
	VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.E, false, game)
end

local function efeitoTeleporte()
	local p = Instance.new("Part")
	p.Shape = Enum.PartType.Ball
	p.Size = Vector3.new(1.5, 1.5, 1.5)
	p.Position = humanoidRootPart.Position
	p.Anchored = true
	p.CanCollide = false
	p.Color = COLOR.teal
	p.Material = Enum.Material.Neon
	p.Transparency = 0.3
	p.Parent = workspace
	game:GetService("Debris"):AddItem(p, 0.5)
end

