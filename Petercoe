	-- ================= FUNÇÕES DO LOG =================
	local function adicionarLog(texto, cor)
		cor = cor or COLOR.textDim
		local hora = os.date("%H:%M:%S")

		local logItem = new("TextLabel", {
			Text = "[" .. hora .. "] " .. texto,
			Font = Enum.Font.Gotham,
			TextSize = 9,
			TextColor3 = cor,
			Size = UDim2.new(1, -8, 0, 14),
			BackgroundTransparency = 1,
			TextXAlignment = Enum.TextXAlignment.Left,
			TextTruncate = Enum.TextTruncate.AtEnd,  -- CORREÇÃO: Trunca texto longo
			Parent = logScroll,
		})

		local logs = {}
		for _, child in ipairs(logScroll:GetChildren()) do
			if child:IsA("TextLabel") then
				table.insert(logs, child)
			end
		end
		if #logs > 15 then
			logs[1]:Destroy()
		end

		logScroll.CanvasSize = UDim2.new(0, 0, 0, logLayout.AbsoluteContentSize.Y + 5)
		task.delay(0.1, function()
			logScroll.CanvasPosition = Vector2.new(0, logScroll.AbsoluteCanvasSize.Y)
		end)
	end

