			statusPillText.Text = "Rodando"
			statusPillText.TextColor3 = COLOR.success
			tween(statusDot, { BackgroundColor3 = COLOR.success }, 0.25)

			adicionarLog("Auto Farm INICIADO", COLOR.success)

			heartbeatConn = RunService.Heartbeat:Connect(function() end)

			task.spawn(function()
				while estado.running do
					local cogumelos = encontrarCogumelosAlvo()
					atualizarConsole()

					if #cogumelos == 0 then
						adicionarLog("Nenhum alvo encontrado", COLOR.danger)
						task.wait(3)
						continue
					end

					for i, cog in ipairs(cogumelos) do
						if not estado.running then break end

						teleportarPara(cog.posicao)
						efeitoTeleporte()

						task.wait(CONFIG.tempoEsperaAposTeleporte)

						if not estado.running then break end

						segurarE(CONFIG.tempoSegurarE)

						if not estado.running then break end

						estado.cogumelosColetados += 1
						statColetados.Text = tostring(estado.cogumelosColetados)

						adicionarLog("Coletado: " .. cog.nome, COLOR.success)

						task.wait(CONFIG.pausaEntreCogumelos)
					end

					if estado.running then
						estado.ciclosCompletos += 1
						adicionarLog("Ciclo " .. estado.ciclosCompletos .. " completo!", COLOR.warning)
						task.wait(1)
					end
				end

				if heartbeatConn then
					heartbeatConn:Disconnect()
					heartbeatConn = nil
				end
			end)

		else
			tween(farmBtn, { BackgroundColor3 = COLOR.teal }, 0.25)
			farmBtnText.Text = "▶  INICIAR AUTO FARM"
			farmBtnText.TextColor3 = Color3.fromRGB(4, 17, 13)

